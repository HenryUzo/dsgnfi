datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum CmsStatus {
  DRAFT
  PUBLISHED
}

enum SiteStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum MembershipRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum SiteDomainType {
  SUBDOMAIN
  CUSTOM
}

enum DomainVerificationStatus {
  PENDING
  VERIFIED
  FAILED
}

enum TemplateStatus {
  ACTIVE
  INACTIVE
}

enum PageStatus {
  DRAFT
  PUBLISHED
}

enum PageRevisionState {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model AdminUser {
  id                     String         @id @default(uuid()) @db.Uuid
  email                  String         @unique
  passwordHash           String
  createdAt              DateTime       @default(now())
  memberships            Membership[]
  createdPageRevisions   PageRevision[] @relation("PageRevisionCreatedBy")
  publishedPageRevisions PageRevision[] @relation("PageRevisionPublishedBy")
  previewTokens          PreviewToken[]
  auditLogs              AuditLog[]     @relation("AuditLogActor")
}

model Tenant {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  slug        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  sites       Site[]
  memberships Membership[]
}

model Site {
  id                String           @id @default(uuid()) @db.Uuid
  tenantId          String           @db.Uuid
  templateId        String?          @db.Uuid
  templateVersionId String?          @db.Uuid
  name              String
  slug              String
  status            SiteStatus       @default(DRAFT)
  isDefault         Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template          Template?        @relation(fields: [templateId], references: [id], onDelete: SetNull)
  templateVersion   TemplateVersion? @relation(fields: [templateVersionId], references: [id], onDelete: SetNull)
  domains           SiteDomain[]
  settings          SiteSettings?
  pages             Page[]
  cmsSections       CmsSection[]
  workMeta          WorkPageMeta[]
  workTags          WorkTag[]
  workProjects      WorkProject[]
  assets            Asset[]
  previewTokens     PreviewToken[]
  auditLogs         AuditLog[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, isDefault])
  @@index([templateId])
  @@index([templateVersionId])
}

model Membership {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @db.Uuid
  tenantId  String         @db.Uuid
  role      MembershipRole
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      AdminUser      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
}

model SiteDomain {
  id                        String                   @id @default(uuid()) @db.Uuid
  siteId                    String                   @db.Uuid
  hostname                  String                   @unique
  type                      SiteDomainType
  isPrimary                 Boolean                  @default(false)
  verificationStatus        DomainVerificationStatus @default(PENDING)
  verificationHost          String?
  verificationValue         String?
  verifiedAt                DateTime?
  lastVerificationAttemptAt DateTime?
  lastVerificationError     String?
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  site                      Site                     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
}

model PreviewToken {
  id            String     @id @default(uuid()) @db.Uuid
  siteId        String     @db.Uuid
  pageKey       String?
  tokenHash     String     @unique
  expiresAt     DateTime
  revokedAt     DateTime?
  note          String?
  createdBy     String?    @db.Uuid
  createdAt     DateTime   @default(now())
  site          Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdByUser AdminUser? @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([siteId, expiresAt])
  @@index([siteId, pageKey])
}

model AuditLog {
  id               String     @id @default(uuid()) @db.Uuid
  actorAdminUserId String?    @db.Uuid
  siteId           String?    @db.Uuid
  action           String
  entityType       String
  entityId         String?
  metadata         Json?
  createdAt        DateTime   @default(now())
  actorAdminUser   AdminUser? @relation("AuditLogActor", fields: [actorAdminUserId], references: [id], onDelete: SetNull)
  site             Site?      @relation(fields: [siteId], references: [id], onDelete: SetNull)

  @@index([siteId, createdAt])
  @@index([actorAdminUserId, createdAt])
  @@index([action, createdAt])
}

model Template {
  id          String            @id @default(uuid()) @db.Uuid
  key         String            @unique
  name        String
  category    String
  description String
  status      TemplateStatus    @default(ACTIVE)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  versions    TemplateVersion[]
  sites       Site[]
}

model TemplateVersion {
  id          String   @id @default(uuid()) @db.Uuid
  templateId  String   @db.Uuid
  version     String
  isActive    Boolean  @default(true)
  manifestKey String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  template    Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sites       Site[]

  @@unique([templateId, version])
  @@index([templateId])
  @@index([manifestKey])
}

model SiteSettings {
  id                String   @id @default(uuid()) @db.Uuid
  siteId            String   @unique @db.Uuid
  logoUrl           String?
  faviconUrl        String?
  tagline           String?
  contactEmail      String?
  contactPhone      String?
  address           String?
  socialLinks       Json?
  seoTitle          String?
  seoDescription    String?
  theme             Json?
  primaryNavigation Json?
  footerNavigation  Json?
  locale            String?
  timezone          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  site              Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
}

model Asset {
  id        String   @id @default(uuid()) @db.Uuid
  siteId    String   @db.Uuid
  url       String
  filename  String
  mimeType  String
  size      Int
  altText   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, createdAt])
}

model Page {
  id                         String         @id @default(uuid()) @db.Uuid
  siteId                     String         @db.Uuid
  pageKey                    String
  slug                       String
  title                      String
  status                     PageStatus     @default(DRAFT)
  seoTitle                   String?
  seoDescription             String?
  currentDraftRevisionId     String?        @db.Uuid
  currentPublishedRevisionId String?        @db.Uuid
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
  site                       Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  revisions                  PageRevision[] @relation("PageRevisions")
  currentDraftRevision       PageRevision?  @relation("CurrentDraftRevision", fields: [currentDraftRevisionId], references: [id], onDelete: SetNull)
  currentPublishedRevision   PageRevision?  @relation("CurrentPublishedRevision", fields: [currentPublishedRevisionId], references: [id], onDelete: SetNull)

  @@unique([siteId, pageKey])
  @@unique([siteId, slug])
  @@index([siteId, status])
}

model PageRevision {
  id                  String            @id @default(uuid()) @db.Uuid
  pageId              String            @db.Uuid
  revisionNumber      Int
  state               PageRevisionState
  content             Json
  schemaVersion       Int               @default(1)
  checksum            String?
  createdBy           String?           @db.Uuid
  publishedBy         String?           @db.Uuid
  createdAt           DateTime          @default(now())
  publishedAt         DateTime?
  page                Page              @relation("PageRevisions", fields: [pageId], references: [id], onDelete: Cascade)
  createdByUser       AdminUser?        @relation("PageRevisionCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  publishedByUser     AdminUser?        @relation("PageRevisionPublishedBy", fields: [publishedBy], references: [id], onDelete: SetNull)
  currentDraftFor     Page[]            @relation("CurrentDraftRevision")
  currentPublishedFor Page[]            @relation("CurrentPublishedRevision")

  @@unique([pageId, revisionNumber])
  @@index([pageId, revisionNumber])
  @@index([pageId, state, createdAt])
}

model CmsSection {
  id            String    @id @default(uuid()) @db.Uuid
  siteId        String    @db.Uuid
  page          String
  section       String
  status        CmsStatus @default(DRAFT)
  draftData     Json      @default(dbgenerated("'{}'::jsonb"))
  publishedData Json      @default(dbgenerated("'{}'::jsonb"))
  updatedAt     DateTime  @updatedAt
  publishedAt   DateTime?
  site          Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, page, section])
  @@index([siteId, page])
}

model WorkPageMeta {
  siteId            String    @db.Uuid
  key               String    @default("work")
  titleDraft        String    @default("Our Work")
  subtitleDraft     String    @default("")
  titlePublished    String    @default("Our Work")
  subtitlePublished String    @default("")
  status            CmsStatus @default(DRAFT)
  publishedAt       DateTime?
  updatedAt         DateTime  @updatedAt
  site              Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@id([siteId, key])
  @@index([siteId])
}

model WorkTag {
  id        String           @id @default(uuid()) @db.Uuid
  siteId    String           @db.Uuid
  name      String
  slug      String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  site      Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  projects  WorkProjectTag[]

  @@unique([siteId, slug])
  @@index([siteId])
}

model WorkProject {
  id                  String           @id @default(uuid()) @db.Uuid
  siteId              String           @db.Uuid
  templateId          String
  titleDraft          String
  slugDraft           String
  excerptDraft        String
  coverImageDraft     String
  draftContent        Json             @default(dbgenerated("'{}'::jsonb"))
  titlePublished      String?
  slugPublished       String?
  excerptPublished    String?
  coverImagePublished String?
  publishedContent    Json             @default(dbgenerated("'{}'::jsonb"))
  status              CmsStatus        @default(DRAFT)
  publishedAt         DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  site                Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  tags                WorkProjectTag[]

  @@unique([siteId, slugDraft])
  @@unique([siteId, slugPublished])
  @@index([siteId, status])
}

model WorkProjectTag {
  projectId String      @db.Uuid
  tagId     String      @db.Uuid
  project   WorkProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag       WorkTag     @relation(fields: [tagId], references: [id], onDelete: Restrict)

  @@id([projectId, tagId])
  @@index([tagId])
}
